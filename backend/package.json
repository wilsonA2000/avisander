    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "file-type": "^16.5.4",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.5",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "engines": {
