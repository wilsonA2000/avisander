# Server
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173,http://localhost:5174

# Paths persistentes (Railway/Fly/VPS). En dev déjalos vacíos.
# En Railway con volumen montado en /data, pon:
#   DB_PATH=/data/database.sqlite
#   UPLOADS_PATH=/data/uploads
DB_PATH=
UPLOADS_PATH=

# Fuerza Secure cookies incluso fuera de NODE_ENV=production. Útil si corres
# detrás de un proxy HTTPS (Cloudflare → Railway, por ejemplo).
COOKIES_SECURE=0

# JWT (both required; use long random strings, min 32 chars each)
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# SMTP (envío real de correos: confirmación al cliente + notificaciones al admin).
# Recomendado: SendGrid free tier (100 emails/día permanentes).
#
# Configuración SendGrid:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=apikey          ← literal, no tu email
#   SMTP_PASS=SG.xxxxxxxx...  ← la API key completa que generaste
#   SMTP_FROM="Avisander <tu-email-verificado@gmail.com>"
#
# Otras opciones: Mailjet, Brevo (Sendinblue), Amazon SES, Mailtrap.
# Si queda vacío en dev, el sistema usa Ethereal (capturas para inspeccionar sin enviar).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Avisander <no-reply@avisander.com>"

# Bold Payments (pasarela Colombia). Obtén las llaves en https://bold.co
#   - BOLD_IDENTITY_KEY: "Llave de identidad" (pública, usada en el widget frontend)
#   - BOLD_SECRET_KEY:   "Llave secreta" (privada, firma de integridad backend)
#   - BOLD_WEBHOOK_SECRET: para verificar HMAC del webhook. En SANDBOX va vacío.
#                         En PRODUCCIÓN es la llave secreta del panel.
# Si no se configura, el botón de pago no aparece y solo queda WhatsApp + Contra entrega.
BOLD_IDENTITY_KEY=
BOLD_SECRET_KEY=
BOLD_WEBHOOK_SECRET=

# Email del admin para notificaciones de pedidos (opcional, se puede editar desde /admin/configuracion)
ADMIN_NOTIFICATION_EMAIL=
