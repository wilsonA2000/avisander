# URL del backend en desarrollo local (usada por el proxy de Vite).
# En producción, el frontend apunta a la API en el mismo dominio o via VITE_API_URL.
VITE_API_PROXY_TARGET=http://localhost:3000

# Opcional: si el frontend se despliega separado del backend,
# define la URL absoluta de la API (sin slash final).
# VITE_API_URL=https://api.avisander.com
